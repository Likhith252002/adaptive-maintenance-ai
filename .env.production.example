# ── Backend (set these in Railway service → Variables) ────────────────────────

# Optional: Anthropic API key for LLM-powered alert narration
ANTHROPIC_API_KEY=sk-ant-...

# CORS: set to your Railway frontend URL (or * for open access)
ALLOWED_ORIGINS=https://your-frontend.up.railway.app

# ── Frontend (set these as Railway build-time variables) ──────────────────────

# Public URL of your Railway backend service (no trailing slash)
VITE_API_URL=https://your-backend.up.railway.app

# WebSocket URL — derived automatically from VITE_API_URL if omitted,
# but can be set explicitly if needed
VITE_WS_URL=wss://your-backend.up.railway.app/ws
