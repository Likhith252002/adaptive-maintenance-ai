# ── Anthropic / LangChain ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── FastAPI ───────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# ── Stream Simulator ──────────────────────────────────────────────────────
STREAM_INTERVAL_SEC=1.0
N_SENSORS=3
INJECT_FAULTS=true

# ── Model ─────────────────────────────────────────────────────────────────
LSTM_SEQ_LEN=30
LSTM_HIDDEN_SIZE=128
LSTM_NUM_LAYERS=2
MODEL_SAVE_PATH=data/models/lstm_best.pt

# ── Drift Detection ───────────────────────────────────────────────────────
DRIFT_REFERENCE_WINDOW=500
DRIFT_TEST_WINDOW=100
DRIFT_THRESHOLD=0.3

# ── Frontend ──────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
